{
  "name": "@app/queue-service",
  "version": "1.0.0",
  "description": "Queue worker: drains scheduled/batch send jobs via graphile-worker with per-session pacing",
  "license": "ISC",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
